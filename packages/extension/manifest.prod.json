{
  "manifest_version": 3,
  "name": "Media Buying Governance",
  "description": "Prevent media buying errors with real-time validation rules injected directly into Meta Ads Manager and Google Ads.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "scripting",
    "webNavigation"
  ],
  "optional_host_permissions": [
    "https://adsmanager.facebook.com/*",
    "https://business.facebook.com/*",
    "https://ads.google.com/*"
  ],
  "host_permissions": [
    "https://mbg-backend-*-uc.a.run.app/*",
    "https://storage.googleapis.com/mbg-admin-portal-*/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content-scripts/*.js",
        "styles/*.css",
        "fonts/*"
      ],
      "matches": [
        "https://adsmanager.facebook.com/*",
        "https://business.facebook.com/*",
        "https://ads.google.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src https://mbg-backend-*-uc.a.run.app https://storage.googleapis.com; img-src 'self' data:;"
  }
}
