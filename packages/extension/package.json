{
  "name": "@media-buying-governance/extension",
  "version": "1.0.0",
  "description": "Chrome Manifest V3 extension for Media Buying Governance",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs --production",
    "zip": "node esbuild.config.mjs --production --zip",
    "build:prod": "node esbuild.config.mjs --production --zip --manifest=manifest.prod.json --env=production",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:meta-fields": "ts-node tests/automated-field-validation.ts",
    "test:chrome-mcp": "echo 'Chrome MCP automated testing requires Chrome MCP server. See CHROME-MCP-SETUP.md for instructions.'",
    "clean": "rm -rf dist dist.zip"
  },
  "dependencies": {
    "@media-buying-governance/shared": "workspace:*",
    "@sentry/browser": "^10.38.0",
    "@splitsoftware/splitio": "^11.10.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.12",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
