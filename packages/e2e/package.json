{
  "name": "@media-buying-governance/e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E test suite for Media Buying Governance Platform",
  "scripts": {
    "test": "playwright test",
    "test:admin": "playwright test --project=admin-portal",
    "test:api": "playwright test --project=api",
    "test:extension": "playwright test --project=extension",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report reports",
    "prepare-extension": "ts-node --esm fixtures/prepare-extension.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "serve": "^14.2.0",
    "typescript": "^5.3.3"
  }
}
